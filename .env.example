# Скопируй этот файл в .env и заполни значения.

# ── Telegram ──────────────────────────────────────────────
# Токен бота — получить у @BotFather.
BOT_TOKEN=
# Твой Telegram ID (узнать: @userinfobot). Бот отвечает только владельцу.
BOT_OWNER_ID=

# ── База данных ───────────────────────────────────────────
# SQLite по умолчанию. Для PostgreSQL: postgresql+asyncpg://user:pass@host/db
DATABASE_URL=sqlite+aiosqlite:///./gamecore.db
DATABASE_ECHO=false

# ── OpenRouter ────────────────────────────────────────────
# Ключ API: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Логирование ───────────────────────────────────────────
LOG_LEVEL=INFO
